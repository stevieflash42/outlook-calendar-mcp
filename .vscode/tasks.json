{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "pip-freeze",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": ["-m", "pip", "freeze", ">", "requirements.txt"]
        },
        {
            "label": "install-requirements",
            "command": "${command:python.interpreterPath}",
            "args": ["-m", "pip", "install", "-r", "requirements.txt"],
            "type": "shell",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            }
        }
    ]
}